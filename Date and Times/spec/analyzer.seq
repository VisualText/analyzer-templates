nlp	funcs	# Declare shared helper functions (NumberType)
nlp	numbers	# Tag numbers as candidate month/day/year values
nlp	ordinals	# Recognize ordinals (1st, 2nd) and am/pm markers
nlp	times	# Recognize clock times (10:04:23 pm, 10:04am)
