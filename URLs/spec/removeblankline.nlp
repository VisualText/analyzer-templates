###############################################
# FILE: removeblankline
# SUBJ: Remove blank-line nodes left by the line segmenter
# AUTH: Kruthika
# CREATED: 2023-6-20 23:31:36
# MODIFIED:
###############################################

@NODES _ROOT
@POST
excise(1,1);	# delete the matched _BLANKLINE node
@RULES
_xNIL <-
	_BLANKLINE	### (1) a blank line to discard
	@@
